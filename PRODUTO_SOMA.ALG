Algoritmo "produto_soma"
// Disciplina  : Lógica de Programaçăo com VisualG
// Professor   : Jailson Costa dos Santos 
// Descriçăo   : Solicita quatro valores, calcula e exibe o produto do
//               primeiro com o terceiro, soma segundo com o quarto
// Autor(a)    : Enzo Hideaki Une
// Data atual  : 04/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   a, b, c, d, p, s:inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite um valor para A: ")
   leia(a)
   escreva("Digite um valor para B: ")
   leia(b)
   escreva("Digite um valor para C: ")
   leia(c)
   escreva("Digite um valor para D: ")
   leia(d)
   
   p <- a * c
   s <- b + d
   
   escreval("")
   
   escreval("O resultado da multiplicaçăo entre A e C é:", p)
   escreval("O resultado da soma entre B e D é:", s)

Fimalgoritmo