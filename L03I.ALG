Algoritmo "L03I"
// Disciplina  : Lógica de Programaçăo com VisualG
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Solicita 10 números e apresenta no final o total do somatório
//               e a média aritmética dos valores lidos
// Autor(a)    : Enzo Hideaki Une
// Data atual  : 05/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   v: vetor[1..10] de inteiro
   contador, soma:inteiro
   media:real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   contador <- 1
   enquanto contador <= 10 faca
      escreva("Digite um valor para o número", contador, ": ")
      leia(v[contador])
      
      soma <- soma + v[contador]

      contador <- contador + 1
   fimenquanto
   
   media <- soma / 10
   
   escreval("")

   escreval("A soma total dos valores inseridos é:", soma)
   escreval("A média aritmética dos valores inseridos é:", media)


Fimalgoritmo