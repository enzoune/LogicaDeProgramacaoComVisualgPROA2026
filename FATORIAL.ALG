Algoritmo "fatorial"
// Disciplina  : Lógica de Programaçăo com VisualG
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Solicita um número, calcula e mostra o valor do fatorial
// Autor(a)    : Enzo Hideaki Une
// Data atual  : 17/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   fatorial, numero, contador:inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   fatorial <- 1

   escreva("Digite um número: ")
   leia(numero)

   para contador de numero-1 ate 1 passo -1 faca
      fatorial <- fatorial * numero
      numero <- numero - 1
   fimpara

   escreval("Valor total do fatorial:", fatorial)

Fimalgoritmo