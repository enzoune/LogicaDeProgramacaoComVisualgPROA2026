Algoritmo "comparacao_areas"
// Disciplina  : Lógica de Programaçăo com VisualG
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Solicita dois valores, calcula a área, verifica e exibe qual figura possui maior área
// Autor(a)    : Enzo Hideaki Une
// Data atual  : 28/03/2026
Var
// Seçăo de Declaraçőes das variáveis
   lado, raio:inteiro
   area_quadrado, area_circulo:real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Digite um valor para o lado do quadrado: ")
   leia(lado)
   escreva("Digite um valor para o raio do círculo: ")
   leia(raio)

   area_quadrado <- lado^2
   area_circulo <- pi * (raio^2)
   
   escreval("")
   
   escreval("A área do quadrado é:", area_quadrado)
   escreval("A área do círculo é:", area_circulo)
   
   escreval("")
   
   se area_quadrado > area_circulo entao
      escreval("O quadrado possui a maior área")
   senao
        escreval("O círculo possui a maior área")
   fimse

Fimalgoritmo