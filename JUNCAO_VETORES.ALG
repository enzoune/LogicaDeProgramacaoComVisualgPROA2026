Algoritmo "juncao_vetores"
// Disciplina  : Lógica de Programaçăo com VisualG
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Ler duas matrizes A e B do tipo vetor com 15 elementos cada.
//               Construir uma matriz C, sendo esta a junçăo das duas outras
//               matrizes. Desta forma, C deverá ter o dobro de elementos, ou
//               seja, 30. Apresentar a matriz C
// Autor(a)    : Enzo Hideaki Une
// Data atual  : 17/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   vetorA:vetor[1..15] de inteiro
   vetorB:vetor[1..15] de inteiro
   vetorC:vetor[1..30] de inteiro
   contador, posicao:inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("--------- VETOR A ---------")
   escreval("")

   para contador de 1 ate 15 passo 1 faca
      escreval("Digite um valor para a posiçăo", contador, " : ")
      leia(vetorA[contador])
   fimpara

   escreval("--------- VETOR B ---------")
   escreval("")

   para contador de 1 ate 15 passo 1 faca
      escreval("Digite um valor para a posiçăo", contador, " : ")
      leia(vetorB[contador])
   fimpara
   
   limpatela

   escreval("------------- VETOR C -------------")
   escreval("")

   posicao <- 1
   
   para contador de 1 ate 30 passo 1 faca
      se contador > 15 entao
         vetorC[contador] <- vetorB[posicao]
         posicao <- posicao + 1
      senao
         vetorC[contador] <- vetorA[contador]
      fimse
      
      escreval("O valor da posiçăo", contador, " é: ", vetorC[contador])
   fimpara

Fimalgoritmo