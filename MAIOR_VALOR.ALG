Algoritmo "maior_valor"
// Disciplina  : Lógica de Programaçăo com VisualG
// Professor   : Jailson Costa dos Santos 
// Descriçăo   : Solicita tręs valores, escreve maior deles
// Autor(a)    : Enzo Hideaki Une
// Data atual  : 29/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
   numero1, numero2, numero3:inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite um número: ")
   leia(numero1)
   escreva("Digite outro número: ")
   leia(numero2)
   escreva("Digite outro número: ")
   leia(numero3)
   
   se numero1 > numero2 entao
      se numero1 > numero3 entao
         escreva("O maior número é:", numero1)
      senao
           escreva("O maior número é:", numero3)
      fimse
   senao
        se numero2 > numero3 entao
           escreva("O maior número é:", numero2)
        senao
             escreva("O maior número é:", numero3)
        fimse
   fimse

Fimalgoritmo