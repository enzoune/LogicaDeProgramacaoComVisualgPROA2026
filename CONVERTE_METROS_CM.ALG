Algoritmo "converte_metros_cm"
// Disciplina  : Lógica de Programação com VisualG
// Professor   : Jailson Costa dos Santos
// Descrição   : Solicita um número em metros e converte para centímetros
// Autor(a)    : Enzo Hideaki Une
// Data atual  : 26/03/2026
Var
// Seção de Declarações das variáveis 
   metros: inteiro
   res: inteiro

Inicio
// Seção de Comandos, procedimento, funções, operadores, etc... 
   escreva("Digite um número em metros: ")
   leia(metros)
   
   res <- metros * 100
   
   escreva("O conversão de metros para centímetros é igual a:", res, "cm")

Fimalgoritmo