Algoritmo "juncao_vetor_par_impar"
// Disciplina  : Lógica de Programaçăo com VisualG
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Ler 15 elementos reais para uma matriz A de uma dimensăo do
//               tipo vetor. Construir uma matriz B de mesmo tipo e dimensăo,
//               observando a seguinte lei de formaçăo: “Todo elemento da
//               matriz A que possuir índice par deverá ter seu elemento
//               dividido por 2; caso contrário, o elemento da matriz A
//               deverá ser multiplicado por 1.5”. Apresentar as matrizes A
//               e B lado a lado
// Autor(a)    : Enzo Hideaki Une
// Data atual  : 17/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   vetorA:vetor[1..6] de inteiro
   vetorB:vetor[1..6] de inteiro
   vetorC:vetor[1..12] de inteiro
   contador:inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("-------------- VETOR A --------------")
   escreval("")

   para contador de 1 ate 6 passo 1 faca
      repita
         escreval("Digite um valor par para posiçăo", contador, " : ")
         leia(vetorA[contador])
      ate vetorA[contador] mod 2 = 0
   fimpara

   escreval("")
   escreval("-------------- VETOR B --------------")
   escreval("")

   para contador de 1 ate 6 passo 1 faca
      repita
         escreval("Digite um valor ímpar para posiçăo", contador, " : ")
         leia(vetorB[contador])
      ate vetorB[contador] mod 2 <> 0
   fimpara

   limpatela

   escreval("-------------- VETOR C --------------")
   escreval("")

   para contador de 1 ate 6 passo 1 faca
      vetorC[contador] <- vetorA[contador]
      vetorC[contador + 6] <- vetorB[contador]
   fimpara

   para contador de 1 ate 12 passo 1 faca
      escreval("O valor da posiçăo", contador, " é: ", vetorC[contador])
   fimpara

Fimalgoritmo

